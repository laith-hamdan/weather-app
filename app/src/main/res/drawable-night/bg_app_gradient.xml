<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="145"
                android:centerColor="@color/bg_sky_dark_mid"
                android:endColor="@color/bg_sky_dark_bottom"
                android:startColor="@color/bg_sky_dark_top"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:width="240dp"
        android:height="240dp"
        android:gravity="top|start"
        android:left="-72dp"
        android:top="-48dp">
        <shape android:shape="oval">
            <solid android:color="@color/bg_moon_glow_dark" />
        </shape>
    </item>
    <item
        android:gravity="bottom"
        android:height="200dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/bg_horizon_haze_dark"
                android:startColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
