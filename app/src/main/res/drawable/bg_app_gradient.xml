<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:centerColor="@color/bg_sky_light_mid"
                android:endColor="@color/bg_sky_light_bottom"
                android:startColor="@color/bg_sky_light_top"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:width="300dp"
        android:height="260dp"
        android:gravity="top|end"
        android:right="-56dp"
        android:top="-36dp">
        <shape android:shape="oval">
            <solid android:color="@color/bg_sun_glow_light" />
        </shape>
    </item>
    <item
        android:gravity="bottom"
        android:height="160dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/bg_horizon_haze_light"
                android:startColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
